ry(\n","    DATASET_PATH+\"/test\",\n","    color_mode=\"grayscale\",\n","    image_size=(IMG_SIZE, IMG_SIZE),\n","    batch_size=BATCH_SIZE,\n","    label_mode=\"categorical\",\n","    shuffle=False\n",")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jElL6gW2ULte","executionInfo":{"status":"ok","timestamp":1771737508709,"user_tz":-330,"elapsed":37932,"user":{"displayName":"Anandu Dinesan","userId":"04646856308894342655"}},"outputId":"db4d8a05-27f0-4584-a7ee-7a7930a4b607"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Found 28709 files belonging to 7 classes.\n","Found 7178 files belonging to 7 classes.\n"]}]},{"cell_type":"code","source":["class_names = train_ds.class_names\n","print(class_names)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PJw3GAFFUULc","executionInfo":{"status":"ok","timestamp":1771734121658,"user_tz":-330,"elapsed":14,"user":{"displayName":"Anandu Dinesan","userId":"04646856308894342655"}},"outputId":"328da951-767a-4336-ab99-73efa347a6d8"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["['angry', 'disgust', 'fear', 'happy', 'neutral', 'sad', 'surprise']\n"]}]},{"cell_type":"code","source":["normalization_layer = tf.keras.layers.Rescaling(1./255)\n","\n","train_ds = train_ds.map(lambda x, y: (normalization_layer(x), y))\n","test_ds = test_ds.map(lambda x, y: (normalization_layer(x), y))"],"metadata":{"id":"D-BNYmL5gx9f"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["for images, labels in train_ds.take(1):\n","    plt.figure(figsize=(8,8))\n","    for i in range(9):\n","        ax = plt.subplot(3,3,i+1)\n","        plt.imshow(images[i].numpy().squeeze(), cmap=\"gray\")\n","        plt.title(class_names[labels[i].numpy().argmax()])\n","        plt.axis(\"off\")\n","    plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":675},"id":"YlpeEix2g7ui","executionInfo":{"status":"ok","timestamp"